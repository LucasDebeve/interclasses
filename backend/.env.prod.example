# Copy this file to backend/.env.prod on your VPS and set strong secrets.
# This file is safe to commit because values are placeholders.

# Docker Compose injects POSTGRES_PASSWORD for the backend service from the shell env.
DATABASE_URL=postgresql+asyncpg://tournament:REPLACE_ME_STRONG_DB_PASSWORD@db:5432/tournament_db

SECRET_KEY=REPLACE_ME_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_ME_STRONG_ADMIN_PASSWORD
